{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Job Scheduler — Scalability Dashboard",
  "uid": "job-scheduler-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application='job-scheduler'}[1m])",
          "legendFormat": "{{method}} {{uri}} ({{status}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application='job-scheduler'}[1m])) * 1000",
          "legendFormat": "P99 {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application='job-scheduler'}[1m])) * 1000",
          "legendFormat": "P50 {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Kafka Events Sent / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(kafka_job_events_sent_total[1m])",
          "legendFormat": "Job Events Sent"
        },
        {
          "expr": "rate(kafka_execution_events_sent_total[1m])",
          "legendFormat": "Execution Events Sent"
        },
        {
          "expr": "rate(kafka_job_events_failed_total[1m])",
          "legendFormat": "Events Failed"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Consumer Batch Duration (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(kafka_consumer_batch_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "P99 Batch Duration"
        },
        {
          "expr": "histogram_quantile(0.50, rate(kafka_consumer_batch_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "P50 Batch Duration"
        }
      ]
    },
    {
      "id": 5,
      "title": "Jobs Fired per Second",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(scheduler_jobs_fired_total[1m])",
          "legendFormat": "Jobs/sec"
        }
      ]
    },
    {
      "id": 6,
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application='job-scheduler'}",
          "legendFormat": "Active Connections"
        },
        {
          "expr": "hikaricp_connections_max{application='job-scheduler'}",
          "legendFormat": "Max Pool Size"
        },
        {
          "expr": "hikaricp_connections_pending{application='job-scheduler'}",
          "legendFormat": "Waiting Threads"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application='job-scheduler', area='heap'} / 1024 / 1024",
          "legendFormat": "Heap Used (MB)"
        },
        {
          "expr": "jvm_memory_max_bytes{application='job-scheduler', area='heap'} / 1024 / 1024",
          "legendFormat": "Heap Max (MB)"
        }
      ]
    },
    {
      "id": 8,
      "title": "Rate Limiter Available Permissions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "resilience4j_ratelimiter_available_permissions{name='jobApi'}",
          "legendFormat": "Available (jobApi)"
        }
      ]
    },
    {
      "id": 9,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name='jobService'}",
          "legendFormat": "CB State (0=CLOSED, 1=OPEN, 2=HALF_OPEN)"
        }
      ]
    },
    {
      "id": 10,
      "title": "Scheduler: Due Jobs per Poll",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "scheduler_due_jobs",
          "legendFormat": "Due Jobs"
        },
        {
          "expr": "rate(scheduler_poll_skipped_total[1m])",
          "legendFormat": "Polls Skipped (lock contention)"
        }
      ]
    },
    {
      "id": 11,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(kafka_consumer_executions_processed_total[1m])",
          "legendFormat": "Processed/sec"
        },
        {
          "expr": "rate(kafka_consumer_executions_failed_total[1m])",
          "legendFormat": "Failed/sec"
        }
      ]
    },
    {
      "id": 12,
      "title": "Jobs Creation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(jobs_created_total[1m])",
          "legendFormat": "Created/sec"
        },
        {
          "expr": "rate(jobs_updated_total[1m])",
          "legendFormat": "Updated/sec"
        }
      ]
    }
  ]
}
